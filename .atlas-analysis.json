  "keyFeatures": [
    "Declarative 3D scene API inspired by Jetpack Compose",
    "Zero OpenGL boilerplate — full GPU abstraction",
    "Orbit camera with smooth inertia and damping",
    "Pinch-to-zoom and orbit gesture recognition",
    "Animated camera transitions with adaptive duration",
    "Primitive elements: Cube, Sphere, Plane",
    "Modifier3D for position, rotation, scale, and size",
    "Typed spatial units system (meters, cm, degrees)",
    "Flat-color material rendering via OpenGL ES 3.0",
    "Modular multi-library architecture with clean dependency direction"
  ],
